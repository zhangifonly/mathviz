{
  "id": "pendulum-phase",
  "title": "单摆相空间",
  "subtitle": "从摆动到翻转",
  "difficulty": "intermediate",
  "targetAge": "高中以上",
  "voice": "yunxi",
  "meta": {
    "author": "MathViz Team",
    "version": "1.0.0",
    "createdAt": "2026-07-18",
    "updatedAt": "2026-07-18"
  },
  "objectives": [
    "理解单摆的运动方程 theta 二阶导等于负 g 除 L 乘 sin theta",
    "认识相空间用角度和角速度描述状态",
    "区分振荡的闭合轨线与翻转的波浪线",
    "理解分界线如何划分两种运动"
  ],
  "prerequisites": [
    "了解正弦函数",
    "了解速度与加速度"
  ],
  "sections": [
    {
      "id": "intro",
      "type": "intro",
      "title": "开场引入",
      "trigger": {
        "type": "auto",
        "delay": 1000
      },
      "lines": [
        {
          "id": "intro-1",
          "text": "还记得小时候荡秋千吗？越荡越高，却总在某处停下来往回落。"
        },
        {
          "id": "intro-2",
          "text": "可如果推得足够猛，秋千就会越过最高点，整整翻一圈。"
        },
        {
          "id": "intro-3",
          "text": "摆动和翻转，看似两回事，其实是同一个方程的两副面孔。"
        }
      ]
    },
    {
      "id": "equation",
      "type": "concept",
      "title": "单摆方程",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "eq-1",
          "text": "设摆角为 theta，单摆遵循 theta 的二阶导等于负 g 除以 L，再乘 sin theta。"
        },
        {
          "id": "eq-2",
          "text": "这个 sin 让方程变得非线性，无法用简单公式一次写出解。"
        },
        {
          "id": "eq-3",
          "text": "于是我们用四阶龙格库塔法，一小步一小步地把轨迹算出来。"
        }
      ]
    },
    {
      "id": "phase",
      "type": "concept",
      "title": "相空间",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "ph-1",
          "text": "换个视角：横轴放角度 theta，纵轴放角速度 omega。"
        },
        {
          "id": "ph-2",
          "text": "每一时刻的状态就是平面上一个点，运动便是这点画出的一条轨迹。"
        },
        {
          "id": "ph-3",
          "text": "这张图叫相空间，它把时间藏进曲线，一眼看清整段运动的命运。"
        }
      ]
    },
    {
      "id": "orbits",
      "type": "concept",
      "title": "振荡与翻转",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "orb-1",
          "text": "能量低时，轨迹是一圈闭合的曲线，对应来回摆动。"
        },
        {
          "id": "orb-2",
          "text": "能量足够大时，轨迹变成上下起伏的波浪线，摆锤不停翻转越顶。"
        },
        {
          "id": "orb-3",
          "text": "恰好分隔这两类的临界轨线，叫做分界线，图中用红色虚线画出。"
        }
      ]
    },
    {
      "id": "interaction",
      "type": "interaction",
      "title": "亲手探索",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "int-1",
          "text": "增减能量轨线的条数，看闭合曲线如何一层层向外扩张。"
        },
        {
          "id": "int-2",
          "text": "高亮某一条轨线，跟着它感受摆锤逼近分界线时的临界状态。"
        }
      ]
    },
    {
      "id": "summary",
      "type": "summary",
      "title": "总结",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "sum-1",
          "text": "单摆方程虽非线性，RK4 却能忠实地画出它的每条轨迹。"
        },
        {
          "id": "sum-2",
          "text": "相空间里，闭合曲线是振荡，波浪线是翻转，分界线泾渭分明。"
        },
        {
          "id": "sum-3",
          "text": "一个秋千，藏着一整幅动力学的地图，我们下次再见！"
        }
      ]
    }
  ]
}