{
  "id": "perceptron",
  "title": "感知机",
  "subtitle": "一条直线分两类",
  "difficulty": "intermediate",
  "targetAge": "高中以上",
  "voice": "yunxi",
  "meta": {
    "author": "MathViz Team",
    "version": "1.0.0",
    "createdAt": "2026-07-18",
    "updatedAt": "2026-07-18"
  },
  "objectives": [
    "理解感知机作为最简人工神经元的结构",
    "掌握加权求和与符号激活的计算",
    "理解按误分类更新权重的学习规则",
    "认识线性可分数据上的收敛性"
  ],
  "prerequisites": [
    "了解平面坐标",
    "了解直线方程"
  ],
  "sections": [
    {
      "id": "intro",
      "type": "intro",
      "title": "开场引入",
      "trigger": {
        "type": "auto",
        "delay": 1000
      },
      "lines": [
        {
          "id": "intro-1",
          "text": "平面上散落着两种颜色的点，我们想用一条直线把它们分开。"
        },
        {
          "id": "intro-2",
          "text": "完成这件事的，是最简单的人工神经元，叫做感知机。"
        },
        {
          "id": "intro-3",
          "text": "它是1958年提出的，也是今天深度学习的起点。"
        }
      ]
    },
    {
      "id": "define",
      "type": "concept",
      "title": "加权求和与激活",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "def-1",
          "text": "感知机给每个输入配一个权重，再把它们加权求和。"
        },
        {
          "id": "def-2",
          "text": "求和加上偏置，就得到一个分数。"
        },
        {
          "id": "def-3",
          "text": "分数大于零判为一类，小于零判为另一类，这就是符号激活。"
        }
      ]
    },
    {
      "id": "update",
      "type": "concept",
      "title": "误分类更新权重",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "upd-1",
          "text": "一开始权重全为零，直线还没找到方向。"
        },
        {
          "id": "upd-2",
          "text": "每遇到一个分错的点，就把权重朝它的方向推一把。"
        },
        {
          "id": "upd-3",
          "text": "推动的公式很简洁：权重加上学习率乘以标签再乘以坐标。"
        }
      ]
    },
    {
      "id": "converge",
      "type": "concept",
      "title": "收敛",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "conv-1",
          "text": "只要两类点本来就能被一条直线分开，我们称它线性可分。"
        },
        {
          "id": "conv-2",
          "text": "感知机收敛定理保证，在有限步之内直线一定能把两类完全分开。"
        }
      ]
    },
    {
      "id": "interaction",
      "type": "interaction",
      "title": "亲手探索",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "int-1",
          "text": "点击单步训练，看直线随着每次更新慢慢转动。"
        },
        {
          "id": "int-2",
          "text": "直到所有点都落在正确的一侧，正确率升到百分之百。"
        }
      ]
    },
    {
      "id": "summary",
      "type": "summary",
      "title": "总结",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "sum-1",
          "text": "感知机用加权求和加符号激活,把平面切成两半。"
        },
        {
          "id": "sum-2",
          "text": "靠误分类更新权重,一步步把分隔线转到正确位置。"
        },
        {
          "id": "sum-3",
          "text": "从一个神经元到深度网络,起点就在这里,我们下次再见！"
        }
      ]
    }
  ]
}