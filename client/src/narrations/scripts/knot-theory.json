{
  "id": "knot-theory",
  "title": "纽结理论",
  "subtitle": "如何用数学分辨两个打结的绳圈",
  "difficulty": "expert",
  "targetAge": "研究生以上",
  "voice": "yunxi",
  "meta": {
    "author": "MathViz Team",
    "version": "1.0.0",
    "createdAt": "2026-07-12",
    "updatedAt": "2026-07-12"
  },
  "objectives": [
    "理解纽结作为三维空间中闭合曲线的数学定义",
    "掌握交叉数与亏格等基本纽结不变量",
    "理解琼斯多项式如何区分不同的纽结",
    "认识环面纽结这一重要的纽结家族"
  ],
  "prerequisites": [
    "拓扑学基础",
    "群与多项式代数",
    "三维几何直觉"
  ],
  "sections": [
    {
      "id": "intro",
      "type": "intro",
      "title": "开场引入",
      "trigger": {
        "type": "auto",
        "delay": 1000
      },
      "lines": [
        {
          "id": "intro-1",
          "text": "把一根绳子随意打个结，再把两端粘起来，就得到一个数学上的纽结。"
        },
        {
          "id": "intro-2",
          "text": "纽结理论研究的核心问题是：两个看似不同的绳圈，能否在不剪断的情况下互相变形。"
        },
        {
          "id": "intro-3",
          "text": "这看似简单，却是拓扑学中最深刻也最迷人的问题之一。"
        }
      ]
    },
    {
      "id": "crossing",
      "type": "concept",
      "title": "交叉数",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "cross-1",
          "text": "要研究纽结，我们先把它压平投影到纸面上，记录每一处上下穿越。"
        },
        {
          "id": "cross-2",
          "text": "一个纽结所有画法中，交叉点最少的那个数目，叫做交叉数。"
        },
        {
          "id": "cross-3",
          "text": "最简单的非平凡纽结是三叶结，它的交叉数是三，无论怎么摆弄都消不掉。"
        }
      ]
    },
    {
      "id": "invariant",
      "type": "concept",
      "title": "纽结不变量",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "inv-1",
          "text": "数学家寻找纽结不变量，也就是变形时保持不变的量，用来区分纽结。"
        },
        {
          "id": "inv-2",
          "text": "亏格衡量填补纽结所需曲面的复杂度，三叶结的亏格是一。"
        },
        {
          "id": "inv-3",
          "text": "更强大的是琼斯多项式，它给每个纽结分配一个多项式，且在变量取一时总等于一。"
        }
      ]
    },
    {
      "id": "torus",
      "type": "concept",
      "title": "环面纽结",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "torus-1",
          "text": "有一类漂亮的纽结缠绕在甜甜圈表面，叫做环面纽结，记作 T p q。"
        },
        {
          "id": "torus-2",
          "text": "当 p 和 q 互质时，它的亏格等于 p 减一乘以 q 减一再除以二，公式简洁而优美。"
        }
      ]
    },
    {
      "id": "interaction",
      "type": "interaction",
      "title": "亲手探索",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "int-1",
          "text": "切换三叶结、八字结和五叶结，观察它们旋转时上下穿越如何变化。"
        },
        {
          "id": "int-2",
          "text": "对照每个纽结的交叉数和亏格，感受不变量如何刻画它们的本质差异。"
        }
      ]
    },
    {
      "id": "summary",
      "type": "summary",
      "title": "总结",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "sum-1",
          "text": "纽结是三维空间中的闭合曲线，交叉数和亏格是最基本的不变量。"
        },
        {
          "id": "sum-2",
          "text": "琼斯多项式的发现连接了纽结理论与量子物理，带来了深远的影响。"
        },
        {
          "id": "sum-3",
          "text": "从一根打结的绳子出发，我们走进了现代拓扑的核心，下次再见。"
        }
      ]
    }
  ]
}