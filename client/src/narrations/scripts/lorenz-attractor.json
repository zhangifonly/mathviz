{
  "id": "lorenz-attractor",
  "title": "洛伦兹吸引子",
  "subtitle": "一只扇动翅膀的数学蝴蝶",
  "difficulty": "expert",
  "targetAge": "研究生以上",
  "voice": "yunxi",
  "meta": {
    "author": "MathViz Team",
    "version": "1.0.0",
    "createdAt": "2026-07-12",
    "updatedAt": "2026-07-12"
  },
  "objectives": [
    "理解洛伦兹方程组作为确定性非线性动力系统",
    "认识奇怪吸引子的几何结构与分形特征",
    "理解对初值的敏感依赖，即蝴蝶效应",
    "体会确定性系统中不可预测性的来源"
  ],
  "prerequisites": [
    "常微分方程基础",
    "相空间与向量场概念",
    "数值积分方法"
  ],
  "sections": [
    {
      "id": "intro",
      "type": "intro",
      "title": "开场引入",
      "trigger": {
        "type": "auto",
        "delay": 1000
      },
      "lines": [
        {
          "id": "intro-1",
          "text": "一九六三年，气象学家洛伦兹在简化对流模型时，写下了三个看似普通的微分方程。"
        },
        {
          "id": "intro-2",
          "text": "他没想到，这组确定的方程，竟画出了一只永不重复的数学蝴蝶。"
        },
        {
          "id": "intro-3",
          "text": "它彻底改变了我们对可预测性的理解，也点燃了混沌理论的火种。"
        }
      ]
    },
    {
      "id": "equations",
      "type": "concept",
      "title": "三个方程",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "eq-1",
          "text": "系统有三个变量 x、y、z，随时间连续变化。"
        },
        {
          "id": "eq-2",
          "text": "x 的变化率等于西格玛乘以 y 减 x；y 的变化率等于 x 乘以 罗 减 z，再减去 y。"
        },
        {
          "id": "eq-3",
          "text": "z 的变化率等于 x 乘 y，再减去 贝塔 乘 z。方程里有乘积项，这正是非线性的来源。"
        }
      ]
    },
    {
      "id": "attractor",
      "type": "concept",
      "title": "奇怪吸引子",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "attr-1",
          "text": "在经典参数下，轨迹被吸向一个固定的区域，但永远不与自己相交。"
        },
        {
          "id": "attr-2",
          "text": "它绕着两个中心不停盘旋，忽左忽右地跳跃，形成蝴蝶的两只翅膀。"
        },
        {
          "id": "attr-3",
          "text": "这个既有界又永不重复的集合，叫做奇怪吸引子，它拥有分形维数。"
        }
      ]
    },
    {
      "id": "butterfly",
      "type": "concept",
      "title": "蝴蝶效应",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "bf-1",
          "text": "让两条轨迹从几乎相同的初始点出发，差异小到千万分之一。"
        },
        {
          "id": "bf-2",
          "text": "起初它们几乎重合，可过不了多久，就分道扬镳，走向完全不同的方向。"
        },
        {
          "id": "bf-3",
          "text": "这就是对初值的敏感依赖，也就是著名的蝴蝶效应。"
        }
      ]
    },
    {
      "id": "interaction",
      "type": "interaction",
      "title": "亲手探索",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "int-1",
          "text": "调节参数 罗，看系统如何从螺旋收敛的稳定态，跨入混沌。"
        },
        {
          "id": "int-2",
          "text": "罗 太小，轨迹会静静地落到一个点；调到二十八附近，蝴蝶才真正展翅。"
        }
      ]
    },
    {
      "id": "summary",
      "type": "summary",
      "title": "总结",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "sum-1",
          "text": "洛伦兹吸引子告诉我们，确定的规则也能孕育出不可预测的行为。"
        },
        {
          "id": "sum-2",
          "text": "有界、非周期、对初值敏感，这三点共同定义了混沌。"
        },
        {
          "id": "sum-3",
          "text": "一只蝴蝶扇动翅膀，或许真能改变远方的风暴，我们下次再见。"
        }
      ]
    }
  ]
}