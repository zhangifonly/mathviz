{
  "id": "parabola-optics",
  "title": "抛物线与光学",
  "subtitle": "平行光为什么会聚到一点",
  "difficulty": "intermediate",
  "targetAge": "高中以上",
  "voice": "yunxi",
  "meta": {
    "author": "MathViz Team",
    "version": "1.0.0",
    "createdAt": "2026-07-12",
    "updatedAt": "2026-07-12"
  },
  "objectives": [
    "理解抛物线由焦点与准线定义",
    "掌握标准抛物线的焦点与准线位置",
    "理解抛物线的反射性质与聚焦原理",
    "了解反射性质在探照灯、卫星天线中的应用"
  ],
  "prerequisites": [
    "了解二次函数图像",
    "了解反射定律"
  ],
  "sections": [
    {
      "id": "intro",
      "type": "intro",
      "title": "开场引入",
      "trigger": {
        "type": "auto",
        "delay": 1000
      },
      "lines": [
        {
          "id": "intro-1",
          "text": "你有没有想过，探照灯里一个小小的灯泡，怎么就能射出笔直的一束强光？"
        },
        {
          "id": "intro-2",
          "text": "卫星天线又是怎么把散射的微弱信号，牢牢收拢到一个接收头上的？"
        },
        {
          "id": "intro-3",
          "text": "答案藏在一条我们很熟悉的曲线里，它就是抛物线。"
        }
      ]
    },
    {
      "id": "define",
      "type": "concept",
      "title": "焦点与准线",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "def-1",
          "text": "抛物线有一个精确的定义：到一个定点的距离，永远等于到一条定直线的距离。"
        },
        {
          "id": "def-2",
          "text": "这个定点叫焦点，这条定直线叫准线。"
        },
        {
          "id": "def-3",
          "text": "对于标准抛物线 x 的平方等于四 p 乘 y，焦点在 y 轴上的 p 处，准线是水平线 y 等于负 p。"
        }
      ]
    },
    {
      "id": "reflect",
      "type": "concept",
      "title": "反射聚焦",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "refl-1",
          "text": "现在让一束平行于对称轴的光，竖直射向这条抛物线。"
        },
        {
          "id": "refl-2",
          "text": "按照反射定律，每条光线打到曲面后都会弹开。神奇的是，它们全都精确地穿过同一个点。"
        },
        {
          "id": "refl-3",
          "text": "这个点，正是焦点。无论光线从哪里射入，反射后都会汇聚到焦点上。"
        }
      ]
    },
    {
      "id": "why",
      "type": "concept",
      "title": "为什么会聚焦",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "why-1",
          "text": "奥秘在于抛物线每一点的切线角度，恰好让入射角等于反射角时，反射线都指向焦点。"
        },
        {
          "id": "why-2",
          "text": "把这个过程反过来，把灯泡放在焦点上，射出的光反射后就变成一束平行光，这就是探照灯。"
        }
      ]
    },
    {
      "id": "interaction",
      "type": "interaction",
      "title": "亲手探索",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "int-1",
          "text": "调节焦准距 p，抛物线开口会变宽或变窄，焦点的高低也随之改变。"
        },
        {
          "id": "int-2",
          "text": "但你会发现，不管开口怎么变，所有平行光始终稳稳地聚在焦点上。"
        }
      ]
    },
    {
      "id": "summary",
      "type": "summary",
      "title": "总结",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "sum-1",
          "text": "抛物线由焦点和准线定义，曲线上每点到两者的距离相等。"
        },
        {
          "id": "sum-2",
          "text": "它的反射性质让平行光聚焦到焦点，也让焦点的光射出平行光。"
        },
        {
          "id": "sum-3",
          "text": "从探照灯到卫星天线，一条曲线连接了数学与生活，我们下次再见！"
        }
      ]
    }
  ]
}