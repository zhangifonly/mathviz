{
  "id": "gaussian-process",
  "title": "高斯过程",
  "subtitle": "为函数本身赋予概率分布",
  "difficulty": "advanced",
  "targetAge": "大学以上",
  "voice": "yunxi",
  "meta": {
    "author": "MathViz Team",
    "version": "1.0.0",
    "createdAt": "2026-07-12",
    "updatedAt": "2026-07-12"
  },
  "objectives": [
    "理解高斯过程是函数上的概率分布",
    "理解核函数如何刻画点与点之间的相关性",
    "掌握后验均值作为预测、方差作为不确定性的含义",
    "感受贝叶斯推断在回归问题中的威力"
  ],
  "prerequisites": [
    "多元高斯分布",
    "条件概率",
    "线性代数基础"
  ],
  "sections": [
    {
      "id": "intro",
      "type": "intro",
      "title": "开场引入",
      "trigger": {
        "type": "auto",
        "delay": 1000
      },
      "lines": [
        {
          "id": "intro-1",
          "text": "普通回归给你一条确定的曲线，可现实里我们常常想问：这条曲线到底有多可信。"
        },
        {
          "id": "intro-2",
          "text": "高斯过程给出的不是一条线，而是无数条可能曲线组成的概率分布。"
        },
        {
          "id": "intro-3",
          "text": "它既告诉你最可能的预测，也诚实地告诉你，哪里心里没底。"
        }
      ]
    },
    {
      "id": "prior",
      "type": "concept",
      "title": "函数上的分布",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "prior-1",
          "text": "想象把函数在每个位置的取值都看成一个随机变量，任意有限个位置一起服从多元高斯分布。"
        },
        {
          "id": "prior-2",
          "text": "这就是高斯过程：一个作用在函数空间上的高斯分布。"
        },
        {
          "id": "prior-3",
          "text": "在还没看到任何数据时，它就是我们对未知函数的先验信念。"
        }
      ]
    },
    {
      "id": "kernel",
      "type": "concept",
      "title": "核函数的作用",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "kernel-1",
          "text": "核函数衡量两个位置有多相关。距离越近，函数值越应该接近。"
        },
        {
          "id": "kernel-2",
          "text": "我们用平方指数核，相关性随距离平方指数衰减。"
        },
        {
          "id": "kernel-3",
          "text": "长度尺度是关键旋钮：它越大，曲线越平滑；越小，曲线波动越快。"
        }
      ]
    },
    {
      "id": "posterior",
      "type": "concept",
      "title": "后验与不确定性",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "post-1",
          "text": "一旦观测到若干数据点，用高斯的条件公式就能算出后验分布。"
        },
        {
          "id": "post-2",
          "text": "后验均值是那条最可能的预测曲线，它会穿过或贴近每个观测点。"
        },
        {
          "id": "post-3",
          "text": "后验方差刻画不确定性：靠近数据处收得很窄，远离数据处则重新张开。"
        }
      ]
    },
    {
      "id": "interaction",
      "type": "interaction",
      "title": "亲手探索",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "int-1",
          "text": "调大长度尺度，看曲线如何变得舒展平滑；调小它，曲线就紧紧扭动去追每个点。"
        },
        {
          "id": "int-2",
          "text": "注意那条浅色的置信带，在数据密集的地方收窄，在两端空旷处张大。"
        }
      ]
    },
    {
      "id": "summary",
      "type": "summary",
      "title": "总结",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "sum-1",
          "text": "高斯过程是函数上的概率分布，核函数编码了我们对光滑度的假设。"
        },
        {
          "id": "sum-2",
          "text": "后验均值给出预测，后验方差给出不确定性，二者缺一不可。"
        },
        {
          "id": "sum-3",
          "text": "这就是它在贝叶斯优化和科学建模里大放异彩的原因，我们下次再见！"
        }
      ]
    }
  ]
}