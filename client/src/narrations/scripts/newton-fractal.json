{
  "id": "newton-fractal",
  "title": "牛顿分形",
  "subtitle": "复平面上的收敛盆地",
  "difficulty": "advanced",
  "targetAge": "高中以上",
  "voice": "yunxi",
  "meta": {
    "author": "MathViz Team",
    "version": "1.0.0",
    "createdAt": "2026-07-18",
    "updatedAt": "2026-07-18"
  },
  "objectives": [
    "理解复数域上的牛顿迭代法",
    "认识收敛盆地的概念",
    "感受分形边界与混沌现象",
    "体会求根算法竟能生成美丽图案"
  ],
  "prerequisites": [
    "了解复数",
    "了解导数与牛顿求根法"
  ],
  "sections": [
    {
      "id": "intro",
      "type": "intro",
      "title": "开场引入",
      "trigger": {
        "type": "auto",
        "delay": 1000
      },
      "lines": [
        {
          "id": "intro-1",
          "text": "牛顿法是解方程求根的经典利器。"
        },
        {
          "id": "intro-2",
          "text": "可你也许想不到，把它搬到复平面上，竟能长出绚烂的分形。"
        },
        {
          "id": "intro-3",
          "text": "今天我们就看，求根这件事怎样画出一幅无穷精细的图案。"
        }
      ]
    },
    {
      "id": "iterate",
      "type": "concept",
      "title": "复数牛顿迭代",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "def-1",
          "text": "对多项式 f，从一个复数 z 出发，反复做 z 减去 f 比 f 的导数。"
        },
        {
          "id": "def-2",
          "text": "这就是牛顿迭代，每一步都把 z 推向离它更近的一个根。"
        },
        {
          "id": "def-3",
          "text": "以 z 三次方减一为例，它在复平面上有三个立方根。"
        }
      ]
    },
    {
      "id": "basin",
      "type": "concept",
      "title": "收敛盆地",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "basin-1",
          "text": "把复平面上每一点当作起点，看它最终收敛到哪个根。"
        },
        {
          "id": "basin-2",
          "text": "收敛到同一个根的所有起点，涂成同一种颜色，这片区域就叫收敛盆地。"
        },
        {
          "id": "basin-3",
          "text": "颜色越亮表示收敛越快，越暗则说明迭代得越久。"
        }
      ]
    },
    {
      "id": "boundary",
      "type": "concept",
      "title": "分形边界",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "edge-1",
          "text": "奇妙的是，不同盆地的边界并不是光滑曲线。"
        },
        {
          "id": "edge-2",
          "text": "无论放大到哪一层，边界上总有三种颜色犬牙交错地纠缠。"
        },
        {
          "id": "edge-3",
          "text": "边界处起点差之毫厘，归宿便谬以千里，这正是混沌。"
        }
      ]
    },
    {
      "id": "interaction",
      "type": "interaction",
      "title": "亲手探索",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "int-1",
          "text": "切换到 z 四次方减一，四个根会织出四色的对称花纹。"
        },
        {
          "id": "int-2",
          "text": "不断放大边界，自相似的细节会一层层浮现，永无止境。"
        }
      ]
    },
    {
      "id": "summary",
      "type": "summary",
      "title": "总结",
      "trigger": {
        "type": "auto",
        "delay": 800
      },
      "lines": [
        {
          "id": "sum-1",
          "text": "复数牛顿迭代按起点把平面分成一块块收敛盆地。"
        },
        {
          "id": "sum-2",
          "text": "盆地边界是无穷精细的分形，藏着混沌的敏感依赖。"
        },
        {
          "id": "sum-3",
          "text": "一个古老的求根算法，画出了数学的绚丽，我们下次再见！"
        }
      ]
    }
  ]
}