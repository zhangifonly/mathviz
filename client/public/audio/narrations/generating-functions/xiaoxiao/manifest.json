      "path": "audio/narrations/generating-functions/xiaoxiao/conv-conv-3.mp3",
      "duration": 1.99,
      "size": 31824,
      "text": "而这恰好就是组合计数里，凑出总和为 k 的方案数。"
    },
    {
      "script_id": "generating-functions",
      "section_id": "apply",
      "line_id": "app-1",
