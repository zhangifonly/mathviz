      "duration": 1.78,
      "size": 28512,
      "text": "一颗骰子的生成函数是 x 加到 x 的六次方。"
    },
    {
      "script_id": "generating-functions",
      "section_id": "apply",
      "line_id": "app-2",
      "filename": "apply-app-2.mp3",
