      "path": "audio/narrations/symmetry/yunxi/summary-sum-2.mp3",
      "duration": 1.84,
      "size": 29520,
      "text": "翻一翻是镜像对称，转一转是旋转对称。"
    },
    {
      "script_id": "symmetry",
      "section_id": "summary",
      "line_id": "sum-3",
