      "path": "audio/narrations/pascal-triangle/yunxi/build-build-2.mp3",
      "duration": 2.18,
      "size": 34848,
      "text": "1，1 1，1 2 1，1 3 3 1，规律清晰而优美。"
    },
    {
      "script_id": "pascal-triangle",
      "section_id": "build",
      "line_id": "build-3",
