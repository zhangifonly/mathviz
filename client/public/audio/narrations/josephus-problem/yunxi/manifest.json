      "text": "拖动滑块改变人数 n 和报数 k，看幸存者如何变化。"
    },
    {
      "script_id": "josephus-problem",
      "section_id": "interaction",
      "line_id": "int-2",
      "filename": "interaction-int-2.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/interaction-int-2.mp3",
