  "voice_key": "yunxi",
  "files": [
    {
      "script_id": "josephus-problem",
      "section_id": "intro",
      "line_id": "intro-1",
      "filename": "intro-intro-1.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/intro-intro-1.mp3",
      "duration": 2.12,
      "size": 33840,
      "text": "相传古代有一群人围成一圈，约定用报数来决定命运。"
    },
    {
      "script_id": "josephus-problem",
      "section_id": "intro",
      "line_id": "intro-2",
      "filename": "intro-intro-2.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/intro-intro-2.mp3",
      "duration": 1.94,
      "size": 30960,
      "text": "他们从第一个人开始报数，数到某个数字的人就要出局。"
    },
    {
      "script_id": "josephus-problem",
      "section_id": "intro",
      "line_id": "intro-3",
      "filename": "intro-intro-3.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/intro-intro-3.mp3",
      "duration": 1.91,
      "size": 30528,
      "text": "一圈又一圈，人越来越少，谁能坚持到最后呢？"
    },
    {
      "script_id": "josephus-problem",
      "section_id": "rule",
      "line_id": "rule-1",
      "filename": "rule-rule-1.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/rule-rule-1.mp3",
      "duration": 2.32,
      "size": 37152,
      "text": "n 个人围成圈，从第一人开始，每数到第 k 个人就让他出局。"
    },
    {
      "script_id": "josephus-problem",
      "section_id": "rule",
      "line_id": "rule-2",
      "filename": "rule-rule-2.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/rule-rule-2.mp3",
      "duration": 2.02,
      "size": 32400,
      "text": "出局后不再参与，从下一个人继续报数，圈子越缩越小。"
    },
    {
      "script_id": "josephus-problem",
      "section_id": "rule",
      "line_id": "rule-3",
      "filename": "rule-rule-3.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/rule-rule-3.mp3",
      "duration": 1.83,
      "size": 29232,
      "text": "如此循环，直到圈里只剩下唯一的一个幸存者。"
    },
    {
      "script_id": "josephus-problem",
      "section_id": "formula",
      "line_id": "formula-1",
      "filename": "formula-formula-1.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/formula-formula-1.mp3",
      "duration": 1.95,
      "size": 31248,
      "text": "直接模拟当然可以，但数学家找到了更漂亮的递推关系。"
    },
    {
      "script_id": "josephus-problem",
      "section_id": "formula",
      "line_id": "formula-2",
      "filename": "formula-formula-2.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/formula-formula-2.mp3",
      "duration": 2.43,
      "size": 38880,
      "text": "用零基编号，只剩一人时答案是零，即 J(1,k)=0。"
    },
    {
      "script_id": "josephus-problem",
      "section_id": "formula",
      "line_id": "formula-3",
      "filename": "formula-formula-3.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/formula-formula-3.mp3",
      "duration": 4.1,
      "size": 65664,
      "text": "每多一个人，答案就整体平移 k 位再取余：J(n,k)=(J(n-1,k)+k)%n。"
    },
    {
      "script_id": "josephus-problem",
      "section_id": "survivor",
      "line_id": "survivor-1",
      "filename": "survivor-survivor-1.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/survivor-survivor-1.mp3",
      "duration": 2.09,
      "size": 33408,
      "text": "从一个人层层递推到 n 个人，最后加一就换回我们熟悉的编号。"
    },
    {
      "script_id": "josephus-problem",
      "section_id": "survivor",
      "line_id": "survivor-2",
      "filename": "survivor-survivor-2.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/survivor-survivor-2.mp3",
      "duration": 2.04,
      "size": 32688,
      "text": "比如七人每数到三出局，幸存者恰好是第四号。"
    },
    {
      "script_id": "josephus-problem",
      "section_id": "survivor",
      "line_id": "survivor-3",
      "filename": "survivor-survivor-3.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/survivor-survivor-3.mp3",
      "duration": 1.86,
      "size": 29808,
      "text": "递推把一次次繁琐的报数，浓缩成短短几步计算。"
    },
    {
      "script_id": "josephus-problem",
      "section_id": "interaction",
      "line_id": "int-1",
      "filename": "interaction-int-1.mp3",
      "path": "audio/narrations/josephus-problem/yunxi/interaction-int-1.mp3",
