      "path": "audio/narrations/nine-point-circle/foot-def-4.mp3",
      "duration": 2.29,
      "size": 36576,
      "text": "三条高交于一点,称为垂心,而三个垂足又是三个新点。"
    },
    {
      "script_id": "nine-point-circle",
      "section_id": "ortho",
