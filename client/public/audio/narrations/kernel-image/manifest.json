      "path": "audio/narrations/kernel-image/theorem-thm-1.mp3",
      "duration": 1.57,
      "size": 25056,
      "text": "像的维数叫秩，核的维数叫零化度。"
    },
    {
      "script_id": "kernel-image",
      "section_id": "theorem",
      "line_id": "thm-2",
