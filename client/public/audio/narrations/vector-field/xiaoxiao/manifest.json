      "line_id": "app-2",
      "filename": "application-app-2.mp3",
      "path": "audio/narrations/vector-field/xiaoxiao/application-app-2.mp3",
      "duration": 1.31,
      "size": 21024,
      "text": "流体力学用它来描述流体的运动。"
