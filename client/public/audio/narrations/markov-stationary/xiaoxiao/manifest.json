      "path": "audio/narrations/markov-stationary/xiaoxiao/converge-conv-2.mp3",
      "duration": 1.97,
      "size": 31536,
      "text": "此时分布满足自己乘矩阵还等于自己，这就是稳态。"
    },
    {
      "script_id": "markov-stationary",
      "section_id": "converge",
      "line_id": "conv-3",
