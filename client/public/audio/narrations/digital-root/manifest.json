      "section_id": "summary",
      "line_id": "sum-1",
      "filename": "summary-sum-1.mp3",
      "path": "audio/narrations/digital-root/summary-sum-1.mp3",
      "duration": 1.57,
      "size": 25200,
      "text": "数字根是反复各位求和后剩下的一位数。"
    },
    {
      "script_id": "digital-root",
      "section_id": "summary",
      "line_id": "sum-2",
