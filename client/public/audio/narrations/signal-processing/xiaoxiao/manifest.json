      "path": "audio/narrations/signal-processing/xiaoxiao/summary-sum-3.mp3",
      "duration": 1.57,
      "size": 25200,
      "text": "采样和滤波是数字信号处理的核心操作。"
    },
    {
      "script_id": "signal-processing",
