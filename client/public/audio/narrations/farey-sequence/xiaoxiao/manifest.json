  "files": [
    {
      "script_id": "farey-sequence",
      "section_id": "intro",
      "line_id": "intro-1",
      "filename": "intro-intro-1.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/intro-intro-1.mp3",
      "duration": 1.32,
      "size": 21168,
      "text": "零和一之间，藏着无穷多个分数。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "intro",
      "line_id": "intro-2",
      "filename": "intro-intro-2.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/intro-intro-2.mp3",
      "duration": 2.1,
      "size": 33552,
      "text": "如果只保留分母不太大的那些，还要求它们既约，会得到什么？"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "intro",
      "line_id": "intro-3",
      "filename": "intro-intro-3.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/intro-intro-3.mp3",
      "duration": 1.94,
      "size": 31104,
      "text": "把它们从小到大排好队，就是一列奇妙而有序的分数。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "define",
      "line_id": "def-1",
      "filename": "define-def-1.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/define-def-1.mp3",
      "duration": 2.72,
      "size": 43488,
      "text": "n 阶法里数列，是所有分母不超过 n 的既约分数，在零到一之间升序排列。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "define",
      "line_id": "def-2",
      "filename": "define-def-2.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/define-def-2.mp3",
      "duration": 3.14,
      "size": 50256,
      "text": "比如五阶，从零一到一一，中间依次是五分之一、四分之一、三分之一，一路排上去。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "define",
      "line_id": "def-3",
      "filename": "define-def-3.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/define-def-3.mp3",
      "duration": 1.77,
      "size": 28368,
      "text": "阶数越大，队伍里挤进的分数就越多，也越密。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "mediant",
      "line_id": "med-1",
      "filename": "mediant-med-1.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/mediant-med-1.mp3",
      "duration": 1.67,
      "size": 26784,
      "text": "从低阶升到高阶，新加进来的分数从哪来？"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "mediant",
      "line_id": "med-2",
      "filename": "mediant-med-2.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/mediant-med-2.mp3",
      "duration": 2.12,
      "size": 33840,
      "text": "答案是中位数：把相邻两分数的分子相加、分母相加。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "mediant",
      "line_id": "med-3",
      "filename": "mediant-med-3.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/mediant-med-3.mp3",
      "duration": 2.49,
      "size": 39888,
      "text": "三分之一和二分之一的中位数，正是五分之二，它恰好落在两者之间。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "neighbor",
      "line_id": "nei-1",
      "filename": "neighbor-nei-1.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/neighbor-nei-1.mp3",
      "duration": 2.67,
      "size": 42768,
      "text": "任意相邻的两个分数 a 比 b 与 c 比 d，都满足 b 乘 c 减 a 乘 d 等于一。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "neighbor",
      "line_id": "nei-2",
      "filename": "neighbor-nei-2.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/neighbor-nei-2.mp3",
      "duration": 2.42,
      "size": 38736,
      "text": "给每个分数画一个福特圆，分母越大圆越小，都稳稳贴在数轴上。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "neighbor",
      "line_id": "nei-3",
      "filename": "neighbor-nei-3.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/neighbor-nei-3.mp3",
      "duration": 2.05,
      "size": 32832,
      "text": "神奇的是，相邻分数的两个圆恰好相切，绝不重叠。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "interaction",
      "line_id": "int-1",
      "filename": "interaction-int-1.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/interaction-int-1.mp3",
      "duration": 1.75,
      "size": 27936,
      "text": "调整阶数，看新的分数如何在缝隙里冒出来。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "interaction",
      "line_id": "int-2",
      "filename": "interaction-int-2.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/interaction-int-2.mp3",
      "duration": 1.97,
      "size": 31536,
      "text": "打开福特圆，感受这些相切的圆铺满数轴的秩序之美。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "summary",
      "line_id": "sum-1",
      "filename": "summary-sum-1.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/summary-sum-1.mp3",
      "duration": 1.73,
      "size": 27648,
      "text": "法里数列把既约分数按大小排成有序的队列。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "summary",
      "line_id": "sum-2",
      "filename": "summary-sum-2.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/summary-sum-2.mp3",
      "duration": 1.82,
      "size": 29088,
      "text": "中位数生成新项，相邻项满足优雅的邻居关系。"
    },
    {
      "script_id": "farey-sequence",
      "section_id": "summary",
      "line_id": "sum-3",
      "filename": "summary-sum-3.mp3",
      "path": "audio/narrations/farey-sequence/xiaoxiao/summary-sum-3.mp3",
      "duration": 1.75,
      "size": 28080,
      "text": "福特圆让这份秩序看得见摸得着，我们下次再见！"
    }
  ],
