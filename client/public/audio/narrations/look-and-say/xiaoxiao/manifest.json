      "filename": "rule-def-2.mp3",
      "path": "audio/narrations/look-and-say/xiaoxiao/rule-def-2.mp3",
      "duration": 2.65,
      "size": 42480,
      "text": "11有两个1，读作21；21是一个2一个1，读作1211。"
    },
    {
      "script_id": "look-and-say",
      "section_id": "rule",
      "line_id": "def-3",
