      "duration": 2.65,
      "size": 42480,
      "text": "再把它送进 sigmoid 函数，这条 S 形曲线会把任意实数压到 0 到 1 之间。"
    },
    {
      "script_id": "logistic-regression",
      "section_id": "sigmoid",
