  "files": [
    {
      "script_id": "riemann-sum",
      "section_id": "intro",
      "line_id": "intro-1",
      "filename": "intro-intro-1.mp3",
      "path": "audio/narrations/riemann-sum/intro-intro-1.mp3",
      "duration": 1.74,
      "size": 27792,
      "text": "一条曲线和横轴之间，围出了一块弯弯的面积。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "intro",
      "line_id": "intro-2",
      "filename": "intro-intro-2.mp3",
      "path": "audio/narrations/riemann-sum/intro-intro-2.mp3",
      "duration": 1.82,
      "size": 29088,
      "text": "它不是规则的矩形或三角形，怎么算出这块面积呢？"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "split",
      "line_id": "def-2",
      "filename": "split-def-2.mp3",
      "path": "audio/narrations/riemann-sum/split-def-2.mp3",
      "duration": 2.1,
      "size": 33552,
      "text": "矩形的宽都相同，高则取决于曲线在这一段的取样值。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "split",
      "line_id": "def-3",
      "filename": "split-def-3.mp3",
      "path": "audio/narrations/riemann-sum/split-def-3.mp3",
      "duration": 2.13,
      "size": 34128,
      "text": "把所有矩形的面积加起来，就得到一个近似值，这就是黎曼和。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "sample",
      "line_id": "samp-1",
      "filename": "sample-samp-1.mp3",
      "path": "audio/narrations/riemann-sum/sample-samp-1.mp3",
      "duration": 2.58,
      "size": 41328,
      "text": "高取在每段的左端点，叫左黎曼和；取在右端点，叫右黎曼和。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "sample",
      "line_id": "samp-2",
      "filename": "sample-samp-2.mp3",
      "path": "audio/narrations/riemann-sum/sample-samp-2.mp3",
      "duration": 2.21,
      "size": 35280,
      "text": "对递增的曲线，左和偏小、右和偏大，一个低估一个高估。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "sample",
      "line_id": "samp-3",
      "filename": "sample-samp-3.mp3",
      "path": "audio/narrations/riemann-sum/sample-samp-3.mp3",
      "duration": 2.24,
      "size": 35856,
      "text": "取在中点的中点和，往往最接近真实面积，误差最小。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "limit",
      "line_id": "lim-1",
      "filename": "limit-lim-1.mp3",
      "path": "audio/narrations/riemann-sum/limit-lim-1.mp3",
      "duration": 2.34,
      "size": 37440,
      "text": "矩形越窄，顶端就越贴合曲线，遗漏和多出的部分都在缩小。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "limit",
      "line_id": "lim-2",
      "filename": "limit-lim-2.mp3",
      "path": "audio/narrations/riemann-sum/limit-lim-2.mp3",
      "duration": 1.81,
      "size": 28944,
      "text": "当分段数趋于无穷，黎曼和收敛到一个确定的值。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "interaction",
      "line_id": "int-2",
      "filename": "interaction-int-2.mp3",
      "path": "audio/narrations/riemann-sum/interaction-int-2.mp3",
      "duration": 2.44,
      "size": 39024,
      "text": "切换左、右、中点三种取样，对比它们逼近真实积分的快慢。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "summary",
      "line_id": "sum-2",
      "filename": "summary-sum-2.mp3",
      "path": "audio/narrations/riemann-sum/summary-sum-2.mp3",
      "duration": 1.92,
      "size": 30672,
      "text": "分得越细越精确，取样方式决定高估还是低估。"
    }
  ],
