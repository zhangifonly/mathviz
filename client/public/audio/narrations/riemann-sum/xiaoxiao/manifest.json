{
  "script_id": "riemann-sum",
  "voice": "zh-CN-XiaoxiaoNeural",
  "voice_key": "xiaoxiao",
  "files": [
    {
      "script_id": "riemann-sum",
      "section_id": "intro",
      "line_id": "intro-1",
      "filename": "intro-intro-1.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/intro-intro-1.mp3",
      "duration": 1.7,
      "size": 27216,
      "text": "一条曲线和横轴之间，围出了一块弯弯的面积。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "intro",
      "line_id": "intro-2",
      "filename": "intro-intro-2.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/intro-intro-2.mp3",
      "duration": 1.79,
      "size": 28656,
      "text": "它不是规则的矩形或三角形，怎么算出这块面积呢？"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "intro",
      "line_id": "intro-3",
      "filename": "intro-intro-3.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/intro-intro-3.mp3",
      "duration": 1.85,
      "size": 29664,
      "text": "古老而聪明的办法，是用许多小矩形去把它拼出来。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "split",
      "line_id": "def-1",
      "filename": "split-def-1.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/split-def-1.mp3",
      "duration": 1.8,
      "size": 28800,
      "text": "把区间平均切成 n 段，每一段配一个细长的矩形。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "split",
      "line_id": "def-2",
      "filename": "split-def-2.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/split-def-2.mp3",
      "duration": 2.02,
      "size": 32256,
      "text": "矩形的宽都相同，高则取决于曲线在这一段的取样值。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "split",
      "line_id": "def-3",
      "filename": "split-def-3.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/split-def-3.mp3",
      "duration": 2.12,
      "size": 33840,
      "text": "把所有矩形的面积加起来，就得到一个近似值，这就是黎曼和。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "sample",
      "line_id": "samp-1",
      "filename": "sample-samp-1.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/sample-samp-1.mp3",
      "duration": 2.41,
      "size": 38592,
      "text": "高取在每段的左端点，叫左黎曼和；取在右端点，叫右黎曼和。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "sample",
      "line_id": "samp-2",
      "filename": "sample-samp-2.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/sample-samp-2.mp3",
      "duration": 2.12,
      "size": 33984,
      "text": "对递增的曲线，左和偏小、右和偏大，一个低估一个高估。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "sample",
      "line_id": "samp-3",
      "filename": "sample-samp-3.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/sample-samp-3.mp3",
      "duration": 2.1,
      "size": 33552,
      "text": "取在中点的中点和，往往最接近真实面积，误差最小。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "limit",
      "line_id": "lim-1",
      "filename": "limit-lim-1.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/limit-lim-1.mp3",
      "duration": 2.32,
      "size": 37152,
      "text": "矩形越窄，顶端就越贴合曲线，遗漏和多出的部分都在缩小。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "limit",
      "line_id": "lim-2",
      "filename": "limit-lim-2.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/limit-lim-2.mp3",
      "duration": 1.81,
      "size": 28944,
      "text": "当分段数趋于无穷，黎曼和收敛到一个确定的值。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "limit",
      "line_id": "lim-3",
      "filename": "limit-lim-3.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/limit-lim-3.mp3",
      "duration": 2.13,
      "size": 34128,
      "text": "这个极限，正是曲线下面积的准确度量，也就是定积分。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "interaction",
      "line_id": "int-1",
      "filename": "interaction-int-1.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/interaction-int-1.mp3",
      "duration": 2.22,
      "size": 35568,
      "text": "增大分段数 n，看误差一步步减小,矩形一点点贴紧曲线。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "interaction",
      "line_id": "int-2",
      "filename": "interaction-int-2.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/interaction-int-2.mp3",
      "duration": 2.32,
      "size": 37152,
      "text": "切换左、右、中点三种取样，对比它们逼近真实积分的快慢。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "summary",
      "line_id": "sum-1",
      "filename": "summary-sum-1.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/summary-sum-1.mp3",
      "duration": 1.49,
      "size": 23904,
      "text": "黎曼和用一排矩形逼近曲线下的面积。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "summary",
      "line_id": "sum-2",
      "filename": "summary-sum-2.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/summary-sum-2.mp3",
      "duration": 1.84,
      "size": 29520,
      "text": "分得越细越精确，取样方式决定高估还是低估。"
    },
    {
      "script_id": "riemann-sum",
      "section_id": "summary",
      "line_id": "sum-3",
      "filename": "summary-sum-3.mp3",
      "path": "audio/narrations/riemann-sum/xiaoxiao/summary-sum-3.mp3",
      "duration": 1.92,
      "size": 30672,
      "text": "分割到无穷,黎曼和便化作定积分,我们下次再见！"
    }
  ],
  "total_duration": 33.96,
  "total_size": 543600
}