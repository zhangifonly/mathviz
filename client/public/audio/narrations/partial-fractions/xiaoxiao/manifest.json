      "path": "audio/narrations/partial-fractions/xiaoxiao/intro-intro-3.mp3",
      "duration": 1.8,
      "size": 28800,
      "text": "有没有办法把它变简单？答案是把它拆开。"
    },
    {
      "script_id": "partial-fractions",
      "section_id": "split",
      "line_id": "def-1",
