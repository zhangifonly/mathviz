      "path": "audio/narrations/function-transform/xiaoxiao/intro-intro-2.mp3",
      "duration": 1.83,
      "size": 29232,
      "text": "它们形状相似，只是被挪动、拉伸或者翻转了。"
    },
    {
      "script_id": "function-transform",
      "section_id": "intro",
      "line_id": "intro-3",
