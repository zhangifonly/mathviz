      "path": "audio/narrations/minimum-spanning-tree/xiaoxiao/prim-prim-2.mp3",
      "duration": 1.57,
      "size": 25200,
      "text": "每一步都并入连接已选区域的那条最短边。"
    },
    {
      "script_id": "minimum-spanning-tree",
      "section_id": "prim",
      "line_id": "prim-3",
