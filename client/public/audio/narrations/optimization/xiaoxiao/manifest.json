      "path": "audio/narrations/optimization/xiaoxiao/constrained-con-3.mp3",
      "duration": 1.71,
      "size": 27360,
      "text": "拉格朗日乘数法是处理等式约束的经典方法。"
    },
    {
      "script_id": "optimization",
      "section_id": "constrained",
      "line_id": "con-4",
