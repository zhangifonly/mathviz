      "section_id": "define",
      "line_id": "def-3",
      "filename": "define-def-3.mp3",
      "path": "audio/narrations/perceptron/xiaoxiao/define-def-3.mp3",
      "duration": 2.19,
      "size": 34992,
      "text": "分数大于零判为一类，小于零判为另一类，这就是符号激活。"
    },
    {
      "script_id": "perceptron",
      "section_id": "update",
