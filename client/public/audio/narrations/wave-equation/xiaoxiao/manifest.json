      "duration": 2.25,
      "size": 36000,
      "text": "有些点始终静止，叫做节点；有些点振幅最大，叫做波腹。"
    },
    {
      "script_id": "wave-equation",
      "section_id": "standing-wave",
      "line_id": "stand-4",
      "filename": "standing-wave-stand-4.mp3",
      "path": "audio/narrations/wave-equation/xiaoxiao/standing-wave-stand-4.mp3",
      "duration": 1.35,
      "size": 21600,
