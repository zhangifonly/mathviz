{
  "script_id": "triangle-centers",
  "voice": "zh-CN-XiaoxiaoNeural",
  "voice_key": "xiaoxiao",
  "files": [
    {
      "script_id": "triangle-centers",
      "section_id": "intro",
      "line_id": "intro-1",
      "filename": "intro-intro-1.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/intro-intro-1.mp3",
      "duration": 1.51,
      "size": 24192,
      "text": "一个普通的三角形，藏着好几个特别的点。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "intro",
      "line_id": "intro-2",
      "filename": "intro-intro-2.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/intro-intro-2.mp3",
      "duration": 1.54,
      "size": 24624,
      "text": "它们由不同的线交汇而成，各有各的脾气。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "intro",
      "line_id": "intro-3",
      "filename": "intro-intro-3.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/intro-intro-3.mp3",
      "duration": 2.5,
      "size": 40032,
      "text": "今天我们来认识其中最经典的四个：重心、外心、内心、垂心。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "centroid-circum",
      "line_id": "cc-1",
      "filename": "centroid-circum-cc-1.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/centroid-circum-cc-1.mp3",
      "duration": 2.13,
      "size": 34128,
      "text": "重心是三条中线的交点，正好是三个顶点坐标的平均值。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "centroid-circum",
      "line_id": "cc-2",
      "filename": "centroid-circum-cc-2.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/centroid-circum-cc-2.mp3",
      "duration": 2.08,
      "size": 33264,
      "text": "它是三角形的平衡点，用手指顶住这里，纸板恰好不倒。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "centroid-circum",
      "line_id": "cc-3",
      "filename": "centroid-circum-cc-3.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/centroid-circum-cc-3.mp3",
      "duration": 2.08,
      "size": 33264,
      "text": "外心是三条边垂直平分线的交点，到三个顶点距离相等。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "centroid-circum",
      "line_id": "cc-4",
      "filename": "centroid-circum-cc-4.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/centroid-circum-cc-4.mp3",
      "duration": 1.87,
      "size": 29952,
      "text": "以外心为圆心，就能画出穿过三个顶点的外接圆。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "incenter-ortho",
      "line_id": "io-1",
      "filename": "incenter-ortho-io-1.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/incenter-ortho-io-1.mp3",
      "duration": 2.02,
      "size": 32256,
      "text": "内心是三条角平分线的交点，到三条边的距离都相等。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "incenter-ortho",
      "line_id": "io-2",
      "filename": "incenter-ortho-io-2.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/incenter-ortho-io-2.mp3",
      "duration": 2.0,
      "size": 31968,
      "text": "以内心为圆心，就能画出恰好贴着三条边的内切圆。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "incenter-ortho",
      "line_id": "io-3",
      "filename": "incenter-ortho-io-3.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/incenter-ortho-io-3.mp3",
      "duration": 2.65,
      "size": 42336,
      "text": "垂心则是三条高线的交点，也就是从每个顶点向对边所作垂线的汇合处。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "euler",
      "line_id": "eu-1",
      "filename": "euler-eu-1.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/euler-eu-1.mp3",
      "duration": 2.48,
      "size": 39600,
      "text": "奇妙的是，重心、外心、垂心这三个点，总是落在同一条直线上。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "euler",
      "line_id": "eu-2",
      "filename": "euler-eu-2.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/euler-eu-2.mp3",
      "duration": 2.52,
      "size": 40320,
      "text": "这条线叫欧拉线，而且重心恰好把外心到垂心的线段分成一比二。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "interaction",
      "line_id": "int-1",
      "filename": "interaction-int-1.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/interaction-int-1.mp3",
      "duration": 1.93,
      "size": 30816,
      "text": "切换不同形状的三角形，看看四个心如何随之移动。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "interaction",
      "line_id": "int-2",
      "filename": "interaction-int-2.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/interaction-int-2.mp3",
      "duration": 2.07,
      "size": 33120,
      "text": "注意钝角三角形里，外心和垂心会跑到三角形外面去。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "summary",
      "line_id": "sum-1",
      "filename": "summary-sum-1.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/summary-sum-1.mp3",
      "duration": 3.3,
      "size": 52848,
      "text": "重心、外心、内心、垂心，分别由中线、垂直平分线、角平分线和高线相交而成。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "summary",
      "line_id": "sum-2",
      "filename": "summary-sum-2.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/summary-sum-2.mp3",
      "duration": 2.21,
      "size": 35424,
      "text": "外心配外接圆，内心配内切圆，而三心又共处欧拉线。"
    },
    {
      "script_id": "triangle-centers",
      "section_id": "summary",
      "line_id": "sum-3",
      "filename": "summary-sum-3.mp3",
      "path": "audio/narrations/triangle-centers/xiaoxiao/summary-sum-3.mp3",
      "duration": 1.49,
      "size": 23904,
      "text": "小小三角形里的大秩序，我们下次再见！"
    }
  ],
  "total_duration": 36.38,
  "total_size": 582048
}